<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.lh.blog.dao.FilesMapper" >
  <resultMap id="BaseResultMap" type="com.lh.blog.pojo.Files" >
    <id column="fid" property="fid" jdbcType="INTEGER" />
    <result column="name" property="name" jdbcType="VARCHAR" />
    <result column="type" property="type" jdbcType="VARCHAR" />
    <result column="uid" property="uid" jdbcType="INTEGER" />
    <result column="link" property="link" jdbcType="VARCHAR" />
    <association property="users" resultMap="com.lh.blog.dao.UsersMapper.BaseResultMap"></association>
  </resultMap>
  <sql id="Base_Column_List" >
    fid, name, type, uid, link
  </sql>

  <select id="queryFilesByPage" resultMap="BaseResultMap">
    select f.*,u.username
    from files f,users u
    where f.uid=u.uid

  </select>

</mapper>